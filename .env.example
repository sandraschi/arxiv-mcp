# Backend bind (web + MCP HTTP)
ARXIV_MCP_HOST=127.0.0.1
ARXIV_MCP_PORT=10770

# Polite arXiv API pacing (seconds between requests)
ARXIV_CLIENT_DELAY_SECONDS=1.0

# Corpus storage (SQLite + markdown files)
ARXIV_MCP_DATA_DIR=

# Optional: Semantic Scholar API key (higher rate limits)
ARXIV_MCP_SEMANTIC_SCHOLAR_API_KEY=
