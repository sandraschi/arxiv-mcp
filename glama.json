{
  "$schema": "https://glama.ai/schemas/mcp.json",
  "name": "arxiv-mcp",
  "version": "0.3.1",
  "description": "FastMCP 3.1 arXiv research server: API + HTML search, Jina full text, SQLite FTS depot, Semantic Scholar lineage, sampling tools (arxiv_agentic_assist), skills, React/Vite dashboard (10770/10771).",
  "author": "Sandra Schieder",
  "license": "MIT",
  "language": "python",
  "framework": "fastmcp",
  "type": "mcp_server",
  "status": "beta",
  "transport": ["stdio", "http"],
  "keywords": [
    "arxiv",
    "mcp",
    "fastmcp",
    "fastmcp-3.1",
    "dual-transport",
    "streamable-http",
    "research",
    "rag",
    "fts5",
    "sqlite",
    "vite",
    "react",
    "fleet"
  ],
  "categories": ["Developer Tools", "Research", "AI Agents", "Web Applications"],
  "homepage": "https://github.com/sandraschi/arxiv-mcp",
  "repository": {
    "url": "https://github.com/sandraschi/arxiv-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "github",
      "identifier": "sandraschi/arxiv-mcp",
      "transport": {
        "type": "stdio",
        "command": "uv",
        "args": ["run", "python", "-m", "arxiv_mcp", "--stdio"]
      }
    },
    {
      "registryType": "github",
      "identifier": "sandraschi/arxiv-mcp",
      "transport": {
        "type": "http",
        "url": "http://127.0.0.1:10770/mcp"
      }
    }
  ],
  "mcpServers": {
    "arxiv-mcp": {
      "name": "arxiv-mcp",
      "command": "uv",
      "args": ["run", "python", "-m", "arxiv_mcp", "--stdio"],
      "env": {},
      "description": "Stdio MCP (default for Claude Desktop / Cursor).",
      "capabilities": {
        "tools": { "enabled": true, "listChanged": true },
        "resources": { "enabled": true },
        "prompts": { "enabled": true },
        "webapp": {
          "enabled": true,
          "url": "http://127.0.0.1:10771",
          "api_url": "http://127.0.0.1:10770"
        }
      }
    },
    "arxiv-mcp-http": {
      "name": "arxiv-mcp-http",
      "url": "http://127.0.0.1:10770/mcp",
      "description": "Streamable HTTP MCP (FastMCP http_app). Requires: uv run python -m arxiv_mcp --serve",
      "capabilities": {
        "tools": { "enabled": true, "listChanged": true },
        "resources": { "enabled": true },
        "prompts": { "enabled": true },
        "webapp": {
          "enabled": true,
          "url": "http://127.0.0.1:10771",
          "api_url": "http://127.0.0.1:10770"
        }
      }
    }
  }
}
