{
  "version": "1.0",
  "description": "Structured tool-usage examples for arxiv-mcp (expand toward 100+ for full SOTA bar).",
  "examples": [
    {"id": "api-search-1", "user_goal": "Find papers on diffusion models in cs.LG", "tools": ["search_papers"], "args_hint": {"query": "diffusion model", "categories": ["cs.LG"], "limit": 15}},
    {"id": "api-search-2", "user_goal": "Search arXiv for 'RLHF' in cs.CL", "tools": ["search_papers"], "args_hint": {"query": "RLHF", "categories": ["cs.CL"], "limit": 20}},
    {"id": "html-search-1", "user_goal": "HTML search for transformers with author Vaswani", "tools": ["search"], "args_hint": {"query": "transformer", "author": "Vaswani", "page": 1}},
    {"id": "html-adv-1", "user_goal": "Papers with 'attention' in title in cs.AI", "tools": ["searchAdvanced"], "args_hint": {"title": "attention", "category": "cs.AI"}},
    {"id": "html-adv-2", "user_goal": "Abstract mentions 'scaling laws'", "tools": ["searchAdvanced"], "args_hint": {"abstract": "scaling laws", "sort_by": "date_desc"}},
    {"id": "meta-api-1", "user_goal": "Metadata for 2401.00001", "tools": ["get_paper_details"], "args_hint": {"paper_id": "2401.00001"}},
    {"id": "meta-html-1", "user_goal": "Scrape abs page for same id", "tools": ["getPaper"], "args_hint": {"id_or_url": "2401.00001"}},
    {"id": "fulltext-html-1", "user_goal": "Experimental HTML markdown", "tools": ["fetch_full_text"], "args_hint": {"paper_id": "2401.00001", "prefer_html": true}},
    {"id": "fulltext-jina-1", "user_goal": "Full text via Jina", "tools": ["getContent"], "args_hint": {"id_or_url": "2401.00001"}},
    {"id": "recent-api-1", "user_goal": "Last 24h in cs.RO", "tools": ["list_category_latest"], "args_hint": {"category": "cs.RO", "hours": 24, "limit": 25}},
    {"id": "recent-html-1", "user_goal": "Recent cs.AI listing", "tools": ["getRecent"], "args_hint": {"category": "cs.AI", "count": 15}},
    {"id": "categories-1", "user_goal": "List category codes", "tools": ["listCategories"], "args_hint": {}},
    {"id": "s2-1", "user_goal": "Citations for an arXiv id", "tools": ["find_connected_papers"], "args_hint": {"paper_id": "2401.00001", "limit": 12}},
    {"id": "ingest-1", "user_goal": "Save paper to local corpus", "tools": ["ingest_paper_to_corpus"], "args_hint": {"paper_id": "2401.00001", "source": "html"}},
    {"id": "compare-1", "user_goal": "Compare two papers' abstracts", "tools": ["compare_papers_convergence"], "args_hint": {"paper_ids": ["2401.00001", "2401.00002"]}},
    {"id": "prompt-1", "user_goal": "Analyst prompt for methods audit", "tools": ["generate_summary_prompt"], "args_hint": {"lens": "methods_audit", "paper_id": "2401.00001"}},
    {"id": "agentic-1", "user_goal": "Plan a literature review on VLMs", "tools": ["arxiv_agentic_assist"], "args_hint": {"goal": "Survey vision-language models 2024-2025"}},
    {"id": "hint-1", "user_goal": "Suggest queries for graph neural networks", "tools": ["arxiv_sampling_hint"], "args_hint": {"topic": "graph neural networks for molecules"}},
    {"id": "chain-1", "user_goal": "Discover then deep-read", "sequence": ["search_papers", "get_paper_details", "fetch_full_text"]},
    {"id": "chain-2", "user_goal": "HTML discover then Jina", "sequence": ["search", "getPaper", "getContent"]},
    {"id": "chain-3", "user_goal": "Graph then ingest", "sequence": ["find_connected_papers", "ingest_paper_to_corpus"]},
    {"id": "error-1", "user_goal": "Handle Jina failure", "note": "Read recovery_options; try fetch_full_text"},
    {"id": "error-2", "user_goal": "Sparse HTML parse", "note": "Check parse_stats blocks_seen vs parsed_ok"},
    {"id": "dash-1", "user_goal": "Open dashboard", "note": "start.ps1 then http://127.0.0.1:10771"},
    {"id": "http-mcp-1", "user_goal": "Use MCP over HTTP", "note": "python -m arxiv_mcp --serve, POST /mcp"},
    {"id": "stdio-1", "user_goal": "Cursor stdio", "note": "uv run python -m arxiv_mcp --stdio"},
    {"id": "skill-1", "user_goal": "Follow bundled skill", "note": "skill://arxiv-researcher"},
    {"id": "env-1", "user_goal": "Rate limits on Semantic Scholar", "note": "Set ARXIV_MCP_SEMANTIC_SCHOLAR_API_KEY"},
    {"id": "env-2", "user_goal": "Slow Jina", "note": "ARXIV_MCP_ARXIV_HTTP_TIMEOUT_SECONDS"},
    {"id": "env-3", "user_goal": "Custom Jina endpoint", "note": "ARXIV_MCP_JINA_READER_BASE_URL"},
    {"id": "fts-1", "user_goal": "Search ingested chunks", "note": "REST GET /api/depot/search?q="},
    {"id": "compare-2", "user_goal": "Bundle three papers", "tools": ["compare_papers_convergence"], "args_hint": {"paper_ids": ["a", "b", "c"]}},
    {"id": "html-search-2", "user_goal": "Pagination page 2", "tools": ["search"], "args_hint": {"query": "LLM", "page": 2, "page_size": 25}},
    {"id": "html-adv-3", "user_goal": "Filter by date range", "tools": ["searchAdvanced"], "args_hint": {"title": "neural", "date_from": "2024-01-01", "date_to": "2024-12-31"}}
  ]
}
